public class missingnumber {
    public static void main(String[] args) {
        int[] arr = {1,2,3,5};
        int n = arr.length + 1;
        int sum = 0;
        for(int i = 0;i<arr.length;i++){
            sum += arr[i];
        }
        int total = n*(n+1)/2;
        System.out.print(total - sum);
    }
}
