import java.util.*;
public class removeduplicates {
    public static void main(String[] args) {
        int[] arr = {1,2,2,3,4,5};
        ArrayList<Integer> a = new ArrayList<>();
        for(int i = 0;i<arr.length;i++){
            a.add(arr[i]);
        }
        LinkedHashSet<Integer> set = new LinkedHashSet<>(a);
        System.out.print(set);
    }
}
